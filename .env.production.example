NODE_ENV=production
PORT=3000

# Vultr single-server SQLite path
DATABASE_URI=file:/app/data/db.sqlite
PAYLOAD_SECRET=change-me-to-a-long-random-secret

# Public routing
APP_DOMAIN=www.garlicton.com
NEXT_PUBLIC_SITE_URL=https://www.garlicton.com

# Cloudflare Turnstile
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# Kakao Map
NEXT_PUBLIC_KAKAO_MAP_KEY=

# SMTP
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
CONTACT_EMAIL=

# Cloudinary
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
