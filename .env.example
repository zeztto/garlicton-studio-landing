# Payload
DATABASE_URI=file:./db.sqlite
PAYLOAD_SECRET=your-secret-here-change-in-production

# Turnstile (get from https://dash.cloudflare.com/)
NEXT_PUBLIC_TURNSTILE_SITE_KEY=your-turnstile-site-key
TURNSTILE_SECRET_KEY=your-turnstile-secret-key

# Kakao Map (get from https://developers.kakao.com/)
NEXT_PUBLIC_KAKAO_MAP_KEY=your-kakao-map-key

# SMTP (configure with actual values)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
CONTACT_EMAIL=contact@yourdomain.com
