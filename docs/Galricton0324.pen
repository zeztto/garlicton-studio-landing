                {
                  "type": "text",
                  "id": "tlN8b",
                  "name": "heroDesc",
                  "fill": "#FFFFFFB3",
                  "textGrowth": "fixed-width-height",
                  "width": "fit_content(598)",
                  "height": "fit_content(153)",
                  "content": "음악에 쏟아부은 시간과 노력은 결코 헛되지 않으며,\n의미있는 결과로 이어진다고 생각합니다.\n아티스트의 비전을 현실로 만들고,\n미래로 나아갈 수 있도록 함께 돕겠습니다",
                  "lineHeight": 1.7,
                  "textAlign": "center",
                  "fontFamily": "ABeeZee",
                  "fontSize": 19,
                  "fontWeight": "normal"
                }
              ]
            }
